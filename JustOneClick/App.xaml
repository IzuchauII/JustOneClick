<Application x:Class="JustOneClick.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:JustOneClick"
             
             StartupUri="MainWindow.xaml">
    
    <Application.Resources>
        <local:BubbleColorConverter x:Key="BubbleColorConverter"/>
        <local:BubbleAlignConverter x:Key="BubbleAlignConverter"/>
        <local:BubbleCornerConverter x:Key="BubbleCornerConverter"/>

        <BitmapImage x:Key="AppLogo" UriSource="pack://application:,,,/Resource/Logo.png"/>


        <Color x:Key="NeonStart">#FF00E5FF</Color>
        <Color x:Key="NeonEnd">#FF8A00FF</Color>
        <SolidColorBrush x:Key="WindowBackgroundBrush" Color="#CC0F0F10"/>
        <SolidColorBrush x:Key="InnerPanelBrush" Color="#CC111217"/>
        <SolidColorBrush x:Key="TextBrush" Color="White"/>


        <!-- Стиль для обычных кнопок заголовка -->
        <Style x:Key="TitleBarButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="4"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#33FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#55FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Стиль для кнопки закрытия (красная при hover) -->
        <Style x:Key="CloseButtonStyle" TargetType="Button" BasedOn="{StaticResource TitleBarButtonStyle}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#FFB00020"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#FF800018"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Анимированная неоновая рамка — вращение градиента -->
        <Style x:Key="NeonAnimatedBorderStyle" TargetType="Border">
            <Setter Property="BorderThickness" Value="1.2"/>
            <Setter Property="CornerRadius" Value="15"/>
            <Setter Property="BorderBrush">
                <Setter.Value>
                    <!-- Начальная позиция: градиент идёт по диагонали -->
                    <LinearGradientBrush x:Name="NeonBrush"
                                 StartPoint="0,0"
                                 EndPoint="1,1">
                        <GradientStop Color="#FF00E5FF" Offset="0.0"/>
                        <GradientStop Color="#FF8A00FF" Offset="0.4"/>
                        <GradientStop Color="#FF00E5FF" Offset="0.7"/>
                        <GradientStop Color="#FF8A00FF" Offset="1.0"/>
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <EventTrigger RoutedEvent="Loaded">
                    <BeginStoryboard>
                        <Storyboard RepeatBehavior="Forever">

                            <!-- Плавное движение StartPoint -->
                            <PointAnimation
                                Storyboard.TargetProperty="BorderBrush.StartPoint"
                                From="0,0"
                                To="1,1"
                                Duration="0:0:4"
                                AutoReverse="False"/>

                            <!-- Плавное движение EndPoint -->
                            <PointAnimation
                                Storyboard.TargetProperty="BorderBrush.EndPoint"
                                From="1,1"
                                To="0,0"
                                Duration="0:0:2"
                                AutoReverse="False"/>

                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Style.Triggers>
        </Style>

        <!-- Стиль RadioButton для режимов -->
        <Style x:Key="ModeRadioStyle" TargetType="RadioButton">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="Margin" Value="0,3"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Bg"
                        CornerRadius="8"
                        Background="Transparent"
                        Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bg"
                                Property="Background"
                                Value="#22FFFFFF"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bg" Property="Background">
                                    <Setter.Value>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                            <GradientStop Color="#3300E5FF" Offset="0"/>
                                            <GradientStop Color="#338A00FF" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>


    </Application.Resources>
</Application>
