<Window x:Class="JustOneClick.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="JustOneClick"
        WindowStyle="None"
        FontFamily="Roboto"
        FontSize="14"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType"
        AllowsTransparency="True"
        Icon="/resource/Logo_Ico.ico"
        Background="Transparent"
        ResizeMode="CanResize"
        Height="600" Width="1000"
        MinWidth="600" MinHeight="420">

    <Window.CommandBindings>
        <CommandBinding Command="ApplicationCommands.Copy"
                        Executed="CopyMessage_Executed"/>
    </Window.CommandBindings>

    <!-- Внешняя неоновая рамка -->
    <!-- Стало — убираем ручной BorderBrush, применяем стиль -->
    <Border Padding="4"
            Style="{StaticResource NeonAnimatedBorderStyle}">

        <Border.Effect>
            <DropShadowEffect BlurRadius="18"
                              ShadowDepth="0"
                              Opacity="0.7"/>
        </Border.Effect>

        <!-- Основной фон окна -->
        <Grid Background="{StaticResource WindowBackgroundBrush}" ClipToBounds="True">
            <!-- Внутренний бордер с тенью -->
            <Border Background="{StaticResource InnerPanelBrush}">

                <Border.Effect>
                    <DropShadowEffect Color="#000000" BlurRadius="30" ShadowDepth="0" Opacity="0.45"/>
                </Border.Effect>

                <Grid>
                    <!-- Header -->
                    <Grid Height="48" VerticalAlignment="Top" Margin="8">
                        <Grid.ColumnDefinitions>
                            <!-- Логотип -->
                            <ColumnDefinition Width="Auto"/>
                            <!-- Кнопка папки -->
                            <ColumnDefinition Width="Auto"/>
                            <!-- Список выпадающий -->
                            <ColumnDefinition Width="500"/>
                            <!-- Перетаскивание -->
                            <ColumnDefinition Width="*"/>
                            <!-- Кнопки -->
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Логотип и название -->
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Grid.Column="0" Margin="8,0">
                            <Image Source="{StaticResource AppLogo}" Width="28" Height="28"/>
                            <TextBlock Text=" JustOneClick" Foreground="{StaticResource TextBrush}" FontWeight="SemiBold" VerticalAlignment="Center" Margin="1,0"/>
                        </StackPanel>

                        <!-- Кнопка выбора папки -->
                        <Button Grid.Column="1" Width="28" Height="28" Margin="8,0,4,0"
                            ToolTip="Выбрать папку с моделями"
                            Click="BtnSelectFolder_Click"
                            Style="{StaticResource TitleBarButtonStyle}">
                            <TextBlock Text="📁" FontSize="14" VerticalAlignment="Center"
                            HorizontalAlignment="Center">
                                <TextBlock.Foreground>
                                    <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                                        <GradientStop Color="#FFCC8C8C"/>
                                        <GradientStop Color="#FFD41B1B" Offset="1"/>
                                    </LinearGradientBrush>
                                </TextBlock.Foreground>
                            </TextBlock>
                        </Button>

                        <!-- Выпадающий список моделей -->
                        <ComboBox x:Name="ModelComboBox"
                      Grid.Column="2"
                      VerticalAlignment="Center"
                      ItemsSource="{Binding ModelFiles}"
                                 
                      SelectedItem="{Binding SelectedModel}"
                      DisplayMemberPath="DisplayName"
                      ToolTip="{Binding SelectedModel.FullPath}"
                      Foreground="Black"
                      BorderThickness="0.4"
                      
                      Height="29"
                      SelectionChanged="ModelComboBox_SelectionChanged" Background="#00000000">
                            <ComboBox.BorderBrush>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="{StaticResource NeonStart}" Offset="0"/>
                                    <GradientStop Color="{StaticResource NeonEnd}" Offset="1"/>
                                </LinearGradientBrush>
                            </ComboBox.BorderBrush>
                        </ComboBox>

                        <!-- Пустая область для перетаскивания -->
                        <Border Grid.Column="3" Background="Transparent" MouseLeftButtonDown="Header_MouseLeftButtonDown"/>

                        <!-- Кнопки -->
                        <StackPanel Grid.Column="4" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,1,0">
                            <Button x:Name="BtnMin" Click="BtnMin_Click" Width="24" Height="24" Margin="4,0" ToolTip="Свернуть" Style="{StaticResource TitleBarButtonStyle}">
                                <Path Data="M0,11 L12,5" Stroke="White" StrokeThickness="2" Stretch="Uniform"/>
                            </Button>

                            <Button x:Name="BtnMax" Click="BtnMax_Click" Width="24" Height="24" Margin="4,0" ToolTip="Развернуть" Style="{StaticResource TitleBarButtonStyle}">
                                <Path Data="M1,3 L11,1 L11,11 L1,11 Z" Stroke="White" StrokeThickness="1.5" Stretch="Uniform"/>
                            </Button>

                            <Button x:Name="BtnClose" Click="BtnClose_Click" Width="24" Height="24" Margin="4,0" ToolTip="Закрыть" Style="{StaticResource CloseButtonStyle}">
                                <Path Data="M1,1 L11,11 M11,1 L1,11" Stroke="Red" StrokeThickness="2.8" Stretch="Uniform"/>
                            </Button>
                        </StackPanel>
                    </Grid>

                    <!-- Основная область (чат) -->
                    <!-- Основная область (чат) -->
                    <Grid Margin="1,84,1,84">

                        <Border x:Name="SearchPanel"
            Visibility="Collapsed"
            VerticalAlignment="Top"
            Background="#CC111217"
            CornerRadius="8"
            Padding="8,6"
            Margin="8,4,8,0"
            Panel.ZIndex="10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <!-- Поле ввода поиска -->
                                <Border Grid.Column="0" CornerRadius="6"
                                        BorderThickness="1" Padding="6,4">
                                    <Border.BorderBrush>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#FF00E5FF" Offset="0"/>
                                            <GradientStop Color="#FF8A00FF" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.BorderBrush>
                                    <TextBox x:Name="SearchBox"
                         Background="Transparent"
                         BorderThickness="0"
                         Foreground="White"
                         CaretBrush="White"
                         FontSize="13"
                         TextChanged="SearchBox_TextChanged"/>
                                </Border>

                                <!-- Счётчик результатов -->
                                <TextBlock x:Name="SearchCounter"
                       Grid.Column="1"
                       Foreground="#88FFFFFF"
                       FontSize="12"
                       VerticalAlignment="Center"
                       Margin="8,0"/>

                                <!-- Кнопки вверх/вниз -->
                                <Button Grid.Column="2" Width="28" Height="28"
                    Margin="2,0" Content="▲"
                    Foreground="White" FontSize="11"
                    Style="{StaticResource TitleBarButtonStyle}"
                    Click="SearchPrev_Click"/>

                                <Button Grid.Column="3" Width="28" Height="28"
                    Margin="2,0" Content="▼"
                    Foreground="White" FontSize="11"
                    Style="{StaticResource TitleBarButtonStyle}"
                    Click="SearchNext_Click"/>
                            </Grid>
                        </Border>

                        <Border x:Name="LoadingBar"
                                        VerticalAlignment="Top"
                                        Margin="8,56,8,0"
                                        Visibility="Collapsed"
                                        CornerRadius="4"
                                        Height="6">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="#FF00E5FF" Offset="0"/>
                                    <GradientStop Color="#FF8A00FF" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>

                            <ProgressBar x:Name="ModelLoadProgress"
                                         Minimum="0" Maximum="100"
                                         Value="0"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         Foreground="Transparent"
                                         Height="6"/>
                        </Border>

                        <!-- Текст статуса загрузки -->
                        <TextBlock x:Name="LoadingStatusText"
                                   VerticalAlignment="Top"
                                   HorizontalAlignment="Center"
                                   Margin="0,64,0,0"
                                   Foreground="#88FFFFFF"
                                   FontSize="11"
                                   Visibility="Collapsed"/>

                        <!-- Скролл для сообщений -->
                        <ScrollViewer x:Name="ChatScroll" VerticalScrollBarVisibility="Hidden" HorizontalScrollBarVisibility="Disabled">
                            <!-- ItemsControl привязан к коллекции Messages в DataContext -->
                            <ItemsControl ItemsSource="{Binding Messages}"
                                          VirtualizingPanel.IsVirtualizing="True"
                                          VirtualizingPanel.VirtualizationMode="Recycling"
                                          ScrollViewer.CanContentScroll="True"
                                          >
                                <!-- Панель элементов: вертикальный стек (виртуализация можно добавить позже) -->
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <VirtualizingStackPanel/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>

                                <!-- Шаблон для каждого сообщения -->
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="6">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>

                                            <!-- Пузырь сообщения -->
                                            <Border Padding="10"
                                                    CornerRadius="{Binding IsUser, Converter={StaticResource BubbleCornerConverter}}"
                                                    Background="{Binding IsUser, Converter={StaticResource BubbleColorConverter}}"
                                                    HorizontalAlignment="{Binding IsUser, Converter={StaticResource BubbleAlignConverter}}"
                                                MaxWidth="640">

                                                <!-- Добавляем контекстное меню -->
                                                <Border.ContextMenu>
                                                    <ContextMenu>
                                                        <MenuItem Header="📋 Копировать"
                                                                  Command="ApplicationCommands.Copy"
                                                                  CommandParameter="{Binding Text}"/>
                                                    </ContextMenu>
                                                </Border.ContextMenu>


                                                <Border.RenderTransform>
                                                    <ScaleTransform ScaleX="0.8" ScaleY="0.8"/>
                                                </Border.RenderTransform>

                                                <Border.Triggers>
                                                    <EventTrigger RoutedEvent="Loaded">
                                                        <BeginStoryboard>
                                                            <Storyboard>
                                                                <!-- Плавное появление -->
                                                                <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                        From="0" To="1"
                                                                        Duration="0:0:0.15"/>

                                                                <!-- POP-эффект -->
                                                                <DoubleAnimation Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleX)"
                                                                        From="0.8" To="1"
                                                                        Duration="0:0:0.15"/>

                                                                <DoubleAnimation Storyboard.TargetProperty="RenderTransform.(ScaleTransform.ScaleY)"
                                                                        From="0.8" To="1"
                                                                        Duration="0:0:0.15"/>

                                                            </Storyboard>
                                                        </BeginStoryboard>
                                                    </EventTrigger>
                                                </Border.Triggers>

                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Effect">
                                                            <Setter.Value>
                                                                <DropShadowEffect BlurRadius="15"
                                                                        ShadowDepth="1"
                                                                        Color="#00000000"/>
                                                            </Setter.Value>
                                                        </Setter>

                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsUser}" Value="True">
                                                                <Setter Property="Effect">
                                                                    <Setter.Value>
                                                                        <DropShadowEffect BlurRadius="15"
                                                                                ShadowDepth="1"
                                                                                Color="MediumTurquoise"/>
                                                                    </Setter.Value>
                                                                </Setter>
                                                            </DataTrigger>

                                                            <DataTrigger Binding="{Binding IsUser}" Value="False">
                                                                <Setter Property="Effect">
                                                                    <Setter.Value>
                                                                        <DropShadowEffect BlurRadius="15"
                                                                                ShadowDepth="1"
                                                                                Color="Black"/>
                                                                    </Setter.Value>
                                                                </Setter>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>

                                                <!-- ВМЕСТО одного TextBlock — аккуратный Grid -->
                                                <Grid>

                                                    <!-- Текст сообщения -->
                                                    <TextBlock Text="{Binding Text}"
                                                               Foreground="White"
                                                               TextWrapping="Wrap"
                                                               Margin="0,0,40,0"/>

                                                    <!-- Время в правом нижнем углу -->
                                                    <TextBlock Text="{Binding Time, StringFormat=HH:mm}"
                                                               Foreground="#AAFFFFFF"
                                                               FontSize="9"
                                                               HorizontalAlignment="Right"
                                                               VerticalAlignment="Bottom"/>
                                                    


                                                </Grid>

                                            </Border>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>


                    <!-- Нижняя панель ввода -->
                    <Grid Height="64" VerticalAlignment="Bottom" Margin="3" >
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <Border Background="Transparent"
                                CornerRadius="14"
                                Padding="8.5"
                                BorderThickness="2"
                                BorderBrush="LightBlue">
                            <Border.Effect>
                                <DropShadowEffect BlurRadius="10"
                                                  ShadowDepth="0"
                                                  Color="LightBlue"/>
                            </Border.Effect>

                            <TextBox x:Name="InputBox" 
                                     Background="Transparent" 
                                     BorderThickness="0" 
                                     Foreground="White" 
                                     PreviewKeyDown="InputBox_PreviewKeyDown" 
                                     AcceptsReturn="True"
                                     Padding="0"
                                     TextWrapping="WrapWithOverflow"/>
                        </Border>

                        <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="8,0,0,0" VerticalAlignment="Center">
                            <!-- Поиск — НОВАЯ КНОПКА -->
                            <Button Width="44" Height="44" Margin="4"
                                    ToolTip="Поиск по чату (Ctrl+F)"
                                    Click="BtnSearch_Click">
                                <TextBlock Text="🔍" FontSize="18"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Button>
                            <!-- Режим ИИ — НОВАЯ КНОПКА -->
                            <Button Width="44" Height="44" Margin="4" ToolTip="{Binding CurrentModeName}" Click="BtnMode_Click">
                                <TextBlock Text="🎭" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Button>
                            <Button Width="44" Height="44" Margin="4" ToolTip="Отправить" Click="Send_Click">➤</Button>
                            <Button x:Name="BtnAttach"
                                    Width="44" 
                                    Height="44"
                                    Click="BtnAttach_Click"
                                    Margin="4" 
                                    IsEnabled="False" 
                                    ToolTip="Прикрепить"       
                                    >📎</Button>
                        </StackPanel>
                    </Grid>

                    <!-- Панель уведомлений (правый верхний угол) -->
                    <StackPanel x:Name="NotificationsPanel" VerticalAlignment="Top" HorizontalAlignment="Right" Margin="0,64,12,0" Width="320"/>

                    <!-- Зоны ресайза (прозрачные) -->
                    <Rectangle x:Name="ResizeLeft" Width="6" HorizontalAlignment="Left" Cursor="SizeWE" MouseDown="ResizeLeft_MouseDown" Fill="Transparent"/>
                    <Rectangle x:Name="ResizeRight" Width="6" HorizontalAlignment="Right" Cursor="SizeWE" MouseDown="ResizeRight_MouseDown" Fill="Transparent"/>
                    <Rectangle x:Name="ResizeTop" Height="6" VerticalAlignment="Top" Cursor="SizeNS" MouseDown="ResizeTop_MouseDown" Fill="Transparent"/>
                    <Rectangle x:Name="ResizeBottom" Height="6" VerticalAlignment="Bottom" Cursor="SizeNS" MouseDown="ResizeBottom_MouseDown" Fill="Transparent"/>
                    <Rectangle x:Name="ResizeTopLeft" Width="10" Height="10" HorizontalAlignment="Left" VerticalAlignment="Top" Cursor="SizeNWSE" MouseDown="ResizeTopLeft_MouseDown" Fill="Transparent"/>
                    <Rectangle x:Name="ResizeTopRight" Width="10" Height="10" HorizontalAlignment="Right" VerticalAlignment="Top" Cursor="SizeNESW" MouseDown="ResizeTopRight_MouseDown" Fill="Transparent"/>
                    <Rectangle x:Name="ResizeBottomLeft" Width="10" Height="10" HorizontalAlignment="Left" VerticalAlignment="Bottom" Cursor="SizeNESW" MouseDown="ResizeBottomLeft_MouseDown" Fill="Transparent"/>
                    <Rectangle x:Name="ResizeBottomRight" Width="10" Height="10" HorizontalAlignment="Right" VerticalAlignment="Bottom" Cursor="SizeNWSE" MouseDown="ResizeBottomRight_MouseDown" Fill="Transparent"/>

                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
