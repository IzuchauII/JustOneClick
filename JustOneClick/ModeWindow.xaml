<Window x:Class="JustOneClick.ModeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Режим ИИ"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        Width="420" Height="520"
        WindowStartupLocation="CenterOwner">

    <!-- Внешняя рамка в стиле основного окна -->
    <Border CornerRadius="14" Padding="3"
            Style="{StaticResource NeonAnimatedBorderStyle}">
        <Border CornerRadius="12"
                Background="#EE111217">

            <Border.Effect>
                <DropShadowEffect BlurRadius="30" ShadowDepth="0"
                                  Color="#000000" Opacity="0.1"/>
            </Border.Effect>

            <Grid Margin="20">
                <Grid.RowDefinitions>
                    <!-- Заголовок -->
                    <RowDefinition Height="Auto"/>
                    <!-- Список режимов -->
                    <RowDefinition Height="Auto"/>
                    <!-- Разделитель -->
                    <RowDefinition Height="Auto"/>
                    <!-- Свой режим -->
                    <RowDefinition Height="*"/>
                    <!-- Кнопки -->
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Заголовок + кнопка закрыть -->
                <Grid Grid.Row="0" Margin="0,0,0,16">
                    <TextBlock Text="🎭 Режим ИИ"
                               Foreground="White"
                               FontSize="16"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"/>
                    <Button HorizontalAlignment="Right"
                            Width="24" Height="24"
                            Click="BtnClose_Click"
                            Style="{StaticResource CloseButtonStyle}">
                        <Path Data="M1,1 L11,11 M11,1 L1,11"
                              Stroke="Red" StrokeThickness="2.5"
                              Stretch="Uniform"/>
                    </Button>
                </Grid>

                <!-- Список фиксированных режимов -->
                <StackPanel Grid.Row="1" Margin="0,0,0,12">

                    <TextBlock Text="Выбери режим"
                               Foreground="#88FFFFFF"
                               FontSize="11"
                               Margin="0,0,0,8"/>

                    <!-- Каждый режим — RadioButton в своём стиле -->
                    <RadioButton x:Name="RbAssistant"
                                 Content="🤖  Ассистент"
                                 Foreground="White"
                                 GroupName="Modes"
                                 Style="{StaticResource ModeRadioStyle}"
                                 Tag="Ты — универсальный помощник. Отвечай чётко, по делу, структурированно. Используй списки где уместно."
                                 Checked="Mode_Checked"/>

                    <RadioButton x:Name="RbHistorian"
                                 Content="📜  Историк"
                                 Foreground="White"
                                 GroupName="Modes"
                                 Style="{StaticResource ModeRadioStyle}"
                                 Tag="Ты — историк-эксперт. Отвечай развёрнуто, приводи исторические факты, даты, контекст эпохи. Говори академическим но доступным языком."
                                 Checked="Mode_Checked"/>

                    <RadioButton x:Name="RbStoryteller"
                                 Content="📖  Рассказчик"
                                 Foreground="White"
                                 GroupName="Modes"
                                 Style="{StaticResource ModeRadioStyle}"
                                 Tag="Ты — талантливый рассказчик. Пиши образно, атмосферно, с деталями. Создавай живые сцены и характеры."
                                 Checked="Mode_Checked"/>

                    <RadioButton x:Name="RbCustom"
                                 Content="✏️  Свой режим"
                                 Foreground="White"
                                 GroupName="Modes"
                                 Style="{StaticResource ModeRadioStyle}"
                                 Checked="Mode_Checked"/>
                </StackPanel>

                <!-- Разделитель -->
                <Separator Grid.Row="2" Margin="0,0,0,12"
                           Background="White"/>

                <!-- Поле своего промпта -->
                <Grid Grid.Row="3" Margin="0,0,0,16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <!-- Кнопка сохранить -->
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Text="Системный промпт своего режима:"
                               Foreground="#88FFFFFF"
                               FontSize="11"
                               Margin="0,0,0,6"/>

                    <Border Grid.Row="1"
                            CornerRadius="8"
                            BorderThickness="1"
                            Padding="8">
                        <Border.BorderBrush>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#FF00E5FF" Offset="0"/>
                                <GradientStop Color="#FF8A00FF" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.BorderBrush>

                        <TextBox x:Name="CustomPromptBox"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 Foreground="White"
                                 TextWrapping="Wrap"
                                 AcceptsReturn="True"
                                 VerticalScrollBarVisibility="Auto"
                                 FontSize="12"
                                 CaretBrush="White"
                                 SelectionBrush="#668A00FF"
                                 IsEnabled="{Binding ElementName=RbCustom, Path=IsChecked}"
                                 Opacity="1"/>
                    </Border>

                    <!-- Кнопка сохранить свой режим -->
                    <Button Grid.Row="2"
                            Content="💾  Сохранить свой режим"
                            Margin="0,8,0,0"
                            Height="32"
                            Click="BtnSaveCustom_Click"
                            IsEnabled="{Binding ElementName=RbCustom, Path=IsChecked}"
                            Style="{StaticResource TitleBarButtonStyle}"
                            Foreground="White"
                            FontSize="12">
                        <Button.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#4400E5FF" Offset="0"/>
                                <GradientStop Color="#448A00FF" Offset="1"/>
                            </LinearGradientBrush>
                        </Button.Background>
                    </Button>
                </Grid>

                <!-- Кнопки Применить / Отмена -->
                <StackPanel Grid.Row="4"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right">

                    <Button Content="Отмена"
                            Width="90" Height="32"
                            Margin="0,0,8,0"
                            Click="BtnCancel_Click"
                            Style="{StaticResource TitleBarButtonStyle}"
                            Foreground="#AAFFFFFF"
                            FontSize="12"/>

                    <Button Content="✔ Применить"
                            Width="110" Height="32"
                            Click="BtnApply_Click"
                            Style="{StaticResource TitleBarButtonStyle}"
                            Foreground="White"
                            FontSize="12">
                        <Button.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#4400E5FF" Offset="0"/>
                                <GradientStop Color="#448A00FF" Offset="1"/>
                            </LinearGradientBrush>
                        </Button.Background>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>
    </Border>
</Window>